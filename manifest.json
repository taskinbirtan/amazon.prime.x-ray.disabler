{
  "manifest_version": 3,
  "name": "Amazon Prime X-Ray Disabler",
  "version": "1.3",
  "description": "Hides the X-Ray panel and pop-ups on Amazon Prime Video so spoilers don't ruin your watch.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "*://*.primevideo.com/*",
    "*://*.amazon.com/*",
    "*://*.amazon.co.uk/*",
    "*://*.amazon.de/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.primevideo.com/*", "*://*.amazon.com/*", "*://*.amazon.co.uk/*", "*://*.amazon.de/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  }
}
